# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/

# OS generated files
.DS_Store
Thumbs.db
desktop.ini

# Environment variables (sensitive)
.env
.env.*

# Scratch / experiments
scratch/

# Unused/deprecated directories inside src
src/web/
src/serve/

# Authentication / OAuth credentials & tokens (DO NOT UPLOAD)
src/auth/

# Data files that may contain personal info
*.xlsx
*.xls
*.csv
*.json
*.JSON

# Specific exclusion for config.json to prevent uploading local paths
config.json
src/config.json

# Local databases
*.db

# Log files (auto-generated)
*.log
logs/
src/logs/

# VS Code & IDEs
.vscode/
*.code-workspace

# Extraction output artifacts
estrazione_*.json
classificazione_*.json
identify_*.json
extracted_documents.json

# SQLite temporary files
GDPHub.db-shm
GDPHub.db-wal

# Exceptions: files that MUST be tracked
!web/locales/*.json
!config.json.example
!Dummy_Ropa.csv